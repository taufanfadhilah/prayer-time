# Supabase (required)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_anon_key

# Sentry crash reporting (optional — app works without it)
# Create a free project at https://sentry.io to get a DSN
# Leave blank to disable Sentry (global error handlers still log to console/logcat)
VITE_SENTRY_DSN=
